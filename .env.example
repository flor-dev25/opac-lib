# ============================================================
# InfoLib Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (sqlx compile-time check) ---
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/lib_mgmt

# --- Dev Mode Bypass ---
# When set, the Rust backend uses this URL directly instead of
# reading db_config.json (which is written by the NSIS installer).
# Remove or comment out this line in production builds.
DEV_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/lib_mgmt

# --- Firebase Sync ---
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id

# --- Feature Flags ---
# Set to "true" to show Google Sign-In button on Login page
VITE_ENABLE_SOCIAL_LOGIN=false
