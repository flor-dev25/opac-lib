# Supabase shared pooler health check.
# Dashboard: Connect > Direct > Connection method: Session pooler.
#
# These separate fields avoid URI encoding issues with special password characters.
SUPABASE_PROJECT_REF=gjtgotwduereuzpjiinw
SUPABASE_DB_POOLER_HOST=aws-1-ap-northeast-1.pooler.supabase.com
SUPABASE_DB_POOLER_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PASSWORD=your-database-password

# Optional alternative: paste the exact pooler URI from the dashboard.
# If your password has special characters, URL-encode them. Example: # becomes %23.
# SUPABASE_DB_POOLER_URL=postgres://postgres.gjtgotwduereuzpjiinw:your-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_POOLER_URL=
SUPABASE_DB_SSL=true
